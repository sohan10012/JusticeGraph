# ── App ──────────────────────────────────────────────────────
APP_NAME="NyayMarg API"
VERSION="2.0.0"
DEBUG=false
ENVIRONMENT=production

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nyaymarg:password@localhost/nyaymarg
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Auth ─────────────────────────────────────────────────────
SECRET_KEY=change-this-in-production-use-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Redis + Celery ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── ML ───────────────────────────────────────────────────────
MODEL_ARTEFACTS_DIR=./app/ml/artefacts
DEFAULT_N_ESTIMATORS=200
DEFAULT_SIMILARITY_TOP_N=5
MIN_PREDICTION_ACCURACY=0.75
RFC_WEIGHT=0.65
LR_WEIGHT=0.35

# ── Upload ───────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=500
UPLOAD_DIR=./uploads

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ── Seed Data ────────────────────────────────────────────────
SEED_COURTS=120
SEED_JUDGES=300
SEED_CASES=7000

# ═══════════════════════════════════════════════════════════════
# EXTERNAL LEGAL APIs  (Auto-enabled if token is present)
# ═══════════════════════════════════════════════════════════════

# ── Indian Kanoon — free non-commercial (api.indiankanoon.org) ────────────────
IK_API_TOKEN=f02f82313a8b4d6b696a07dd41e9137b73b71400
# IK_ENABLED=  # [AUTO] Enabled if IK_API_TOKEN is present

# ── kanoon.dev — structured Indian law API (kanoon.dev) ──────────────────────
KANOON_DEV_API_KEY=
# KANOON_DEV_ENABLED=  # [AUTO] Enabled if KANOON_DEV_API_KEY is present

# ── ECIAPI — FREE, no auth (eciapi.akshit.me) ────────────────────────────────
ECIAPI_ENABLED=True  # [ALWAYS ON] No key required

# ── eCourtsIndia.com — ₹200 free credits (ecourtsindia.com/api) ──────────────
ECOURTSINDIA_TOKEN=eci_live_vwe2cxxlxqrux2rzh65pclqgi7m12agk
# ECOURTSINDIA_ENABLED=  # [AUTO] Enabled if ECOURTSINDIA_TOKEN is present

# ── data.gov.in — official government datasets (data.gov.in) ─────────────────
DATA_GOV_API_KEY=
# DATA_GOV_ENABLED=  # [AUTO] Enabled if DATA_GOV_API_KEY is present

# ── DDL Judicial Dataset — 81M real cases (devdatalab.org/judicial-data) ──────
# Download CSV files → ./data/ddl_judicial/ then set DDL_ENABLED=True
DDL_LOCAL_PATH=./data/ddl_judicial
DDL_ENABLED=False

# ── CourtListener — US legal data, free token (courtlistener.com) ─────────────
COURTLISTENER_TOKEN=4aec1217ad95727791b58c570db4599643aae041
# COURTLISTENER_ENABLED=  # [AUTO] Enabled if COURTLISTENER_TOKEN is present

# ── Global API settings ───────────────────────────────────────────────────────
EXTERNAL_API_TIMEOUT_SECONDS=15
EXTERNAL_API_MAX_RETRIES=3
EXTERNAL_API_CACHE_TTL_SECONDS=3600
EXTERNAL_API_RATE_LIMIT_PER_MIN=30
RANDOM_SEED=42

# ── Docker / Local DB ────────────────────────────────────────
DB_PASSWORD=1001



