# ── App ──────────────────────────────────────────────────────
APP_NAME="NyayMarg API"
VERSION="2.0.0"
DEBUG=false
ENVIRONMENT=production

# ── Database ─────────────────────────────────────────────────
# Example: postgresql+asyncpg://user:password@localhost/dbname
DATABASE_URL=postgresql+asyncpg://nyaymarg:your_password_here@localhost/nyaymarg
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DB_PASSWORD=your_db_password_here

# ── Auth ─────────────────────────────────────────────────────
# Generate a secure random string for production
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Redis + Celery ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── ML ───────────────────────────────────────────────────────
MODEL_ARTEFACTS_DIR=./app/ml/artefacts
DEFAULT_N_ESTIMATORS=200
DEFAULT_SIMILARITY_TOP_N=5
MIN_PREDICTION_ACCURACY=0.75
RFC_WEIGHT=0.65
LR_WEIGHT=0.35

# ── Upload ───────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=500
UPLOAD_DIR=./uploads

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ── Seed Data ────────────────────────────────────────────────
SEED_COURTS=120
SEED_JUDGES=300
SEED_CASES=7000

# ═══════════════════════════════════════════════════════════════
# EXTERNAL LEGAL APIs
# ═══════════════════════════════════════════════════════════════

# ── Indian Kanoon — api.indiankanoon.org ─────────────────────
IK_API_TOKEN=your_ik_api_token_here
IK_ENABLED= TRUE
# ── kanoon.dev — structured Indian law API ───────────────────
KANOON_DEV_API_KEY=your_kanoon_dev_api_key_here
# KANOON_DEV_ENABLED=  # [AUTO] Enabled if KANOON_DEV_API_KEY is present

# ── SooperKanoon — sooperkanoon.com/api ──────────────────────
SOOPERKANOON_GUID=your_sooperkanoon_guid_here
# SOOPERKANOON_ENABLED=  # [AUTO] Enabled if SOOPERKANOON_GUID is present

# ── ECIAPI — FREE, no auth (eciapi.akshit.me) ────────────────
ECIAPI_ENABLED=True  # [ALWAYS ON] No key required

# ── eCourtsIndia.com — ecourtsindia.com/api ──────────────────
ECOURTSINDIA_TOKEN=your_ecourts_token_here
ECOURTSINDIA_ENABLED=TRUE  # [AUTO] Enabled if ECOURTSINDIA_TOKEN is present

# ── data.gov.in — official government datasets ───────────────
DATA_GOV_API_KEY=your_data_gov_api_key_here
# DATA_GOV_ENABLED=  # [AUTO] Enabled if DATA_GOV_API_KEY is present

# ── DDL Judicial Dataset — devdatalab.org/judicial-data ──────
# Download CSV files → ./data/ddl_judicial/ then set DDL_ENABLED=True
DDL_LOCAL_PATH=./data/ddl_judicial
DDL_ENABLED=False

# ── CourtListener — courtlistener.com ────────────────────────
COURTLISTENER_TOKEN=your_courtlistener_token_here
# COURTLISTENER_ENABLED=  # [AUTO] Enabled if COURTLISTENER_TOKEN is present

# ── Global API settings ──────────────────────────────────────
EXTERNAL_API_TIMEOUT_SECONDS=15
EXTERNAL_API_MAX_RETRIES=3
EXTERNAL_API_CACHE_TTL_SECONDS=3600
EXTERNAL_API_RATE_LIMIT_PER_MIN=30
RANDOM_SEED=42